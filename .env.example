# ===== Proof of VARIATIONAL — configuration =====
# 1) Get an API key at https://twitterapi.io (sign up, copy the key from the dashboard)
TWITTERAPI_KEY=your_twitterapi_io_key_here

# Port the server listens on (most hosts set this automatically)
PORT=3000

# How often the data refreshes. This number is shown on the site itself.
UPDATE_INTERVAL_HOURS=24

# How far back to look. More = more cost.
LOOKBACK_DAYS=7

# Volume / cost controls. Each page ≈ 20 tweets. More pages = more data = higher cost.
LEADERBOARD_PAGES=15
SCAN_PAGES=6
TOP_LIMIT=50

# What counts as a Variational mention (Twitter advanced-search syntax).
QUERY_TERMS=(variational OR @variational_io OR $VAR)
